{
  "name": "CPU",
  "build": {
    "args": {
      "PYTHON_VERSION": "3.12",
      "UBI_VERSION": "9"
    }
  },
  "postStartCommand": "${containerWorkspaceFolder}/.devcontainer/cpu/postStartCommand.sh",
  "hostRequirements": {
    "cpus": 4,
    "gpu": false
  },
  "runArgs": [
    "--userns=keep-id:uid=1000,gid=1000",
    "--security-opt=label=disable"
  ]
}